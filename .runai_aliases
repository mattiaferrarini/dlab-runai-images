# RUNAI ALIASES
# Global variable to store current context
RUNAI_CURRENT_CTX="rcp"

# Function to set the current context
set_runai_context() {
    RUNAI_CURRENT_CTX="$1"
}

# Function to use the appropriate runai command based on context
runai_context() {
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        runai-rcp-prod "$@"
    else
        echo "Invalid RUNAI_CURRENT_CTX: $RUNAI_CURRENT_CTX"
        return 1
    fi
}

# Function to use context-aware runai command
runai() {
	echo "Current context: $RUNAI_CURRENT_CTX"
    runai_context "$@"
}

rpf() {
    kubectl port-forward $1-0-0 2222:22
}

rs() {
    local pvc_name
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        pvc_name="dlab-scratch"
    else
        pvc_name="runai-dlab-{GASPAR_NAME}-scratch"
    fi
    runai_context submit -i ghcr.io/mattiaferrarini/dlab-runai-images/unified:master --pvc "$pvc_name:/mnt" "$@"
}

rs_cpu() {
    if [ $# -lt 2 ]; then
        echo "Usage: rs_cpu <cpu-count> <job-name> [flags...] [-- <command...>]"
        return 1
    fi

    local cpu_count="$1"
    shift
    local job_name="$1"
    shift

    local in_cmd=0
    local submit_args=()
    local cmd_args=()

    for arg in "$@"; do
        if [ "$in_cmd" -eq 1 ]; then
            cmd_args+=("$arg")
        elif [ "$arg" = "--" ]; then
            in_cmd=1
        else
            submit_args+=("$arg")
        fi
    done

    # If no '--' was provided, assume all remaining arguments are the command for backward compatibility
    if [ "$in_cmd" -eq 0 ]; then
        cmd_args=("${submit_args[@]}")
        submit_args=()
    fi

    local pvc_name
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        pvc_name="dlab-scratch"
    else
        pvc_name="runai-dlab-{GASPAR_NAME}-scratch" # Replace {GASPAR_NAME} if needed
    fi
    
    runai_context submit -i ghcr.io/mattiaferrarini/dlab-runai-images/unified:master \
        --pvc "$pvc_name:/mnt" \
        --cpu "$cpu_count" \
        "${submit_args[@]}" \
        "$job_name" \
        -- "cd understanding-weird-generalizations && ${cmd_args[*]}"
}

rs_gen() {
    local pvc_name
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        pvc_name="dlab-scratch"
    else
        pvc_name="runai-dlab-{GASPAR_NAME}-scratch" # Replace {GASPAR_NAME} if needed
    fi
    
    # The first argument is the job name
    local job_name="$1"
    shift # Remove the job name from the arguments list, leaving only the command to run
    
    runai_context submit -i ghcr.io/mattiaferrarini/dlab-runai-images/generalizations:master \
        --pvc "$pvc_name:/mnt" \
        -g 1.0 \
        "$job_name" \
        -- "cd understanding-weird-generalizations && $*"
}

