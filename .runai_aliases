# RUNAI ALIASES
# Global variable to store current context
RUNAI_CURRENT_CTX="rcp"

# Function to set the current context
set_runai_context() {
    RUNAI_CURRENT_CTX="$1"
}

# Function to use the appropriate runai command based on context
runai_context() {
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        runai-rcp-prod "$@"
    else
        echo "Invalid RUNAI_CURRENT_CTX: $RUNAI_CURRENT_CTX"
        return 1
    fi
}

# Function to use context-aware runai command
runai() {
	echo "Current context: $RUNAI_CURRENT_CTX"
    runai_context "$@"
}

rpf() {
    kubectl port-forward $1-0-0 2222:22
}

rs() {
    local pvc_name
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        pvc_name="dlab-scratch"
    else
        pvc_name="runai-dlab-{GASPAR_NAME}-scratch"
    fi
    runai_context submit -i ghcr.io/jkminder/dlab-runai-images/pytorch:master --pvc "$pvc_name:/mnt" "$@"
}

rs_cpu() {
    if [ $# -lt 3 ]; then
        echo "Usage: rs_cpu <cpu-count> <job-name> <command...>"
        return 1
    fi

    local cpu_count="$1"
    shift
    local job_name="$1"
    shift

    rs --cpu "$cpu_count" "$job_name" -- "$@"
}

rs_gen() {
    local pvc_name
    if [ "$RUNAI_CURRENT_CTX" = "rcp" ]; then
        pvc_name="dlab-scratch"
    else
        pvc_name="runai-dlab-{GASPAR_NAME}-scratch" # Replace {GASPAR_NAME} if needed
    fi
    
    # The first argument is the job name
    local job_name="$1"
    shift # Remove the job name from the arguments list, leaving only the command to run
    
    runai_context submit -i ghcr.io/mattiaferrarini/dlab-runai-images/generalizations:master \
        --pvc "$pvc_name:/mnt" \
        -g 1.0 \
        "$job_name" \
        -- "cd understanding-weird-generalizations && $*"
}

